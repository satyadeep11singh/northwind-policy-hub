{
  "name": "northwind-policy-hub",
  "version": "1.0.0",
  "description": "NorthWind Insurance Policy Hub — customer self-service portal for auto and home insurance policies in Ontario, Canada.",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "node server/index.js",
    "seed": "node server/seed/index.js",
    "test": "jest --forceExit --coverage",
    "test:ci": "jest --forceExit --coverage --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint server/**/*.js --ignore-pattern server/**/*.test.js --max-warnings=0"
  },
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "applicationinsights": "^3.4.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["server/**/*.js", "!server/seed/**"]
  }
}
