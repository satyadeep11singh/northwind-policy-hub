# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_EXPIRES_IN=8h

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas (default) — set DB_PROVIDER=atlas
# Cosmos DB for MongoDB  — set DB_PROVIDER=cosmosdb and update URI
DB_PROVIDER=atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/northwind-policy-hub?retryWrites=true&w=majority

# ── Azure Key Vault (production) ─────────────────────────────────────────────
# When running on App Service with Managed Identity, secrets are pulled from
# Key Vault at startup. Set KEY_VAULT_URI to enable; leave blank for local dev.
KEY_VAULT_URI=

# ── Application Insights ─────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Azure Container Registry (CI use only) ───────────────────────────────────
ACR_NAME=
ACR_LOGIN_SERVER=

# ── Azure (CD / Jenkins use only) ────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=
WEBAPP_NAME=
